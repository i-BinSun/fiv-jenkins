# Email Configuration for Jenkins Test Notification
# Copy this file to .env and fill in your actual values

# SMTP Server Settings
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# SMTP Authentication (for Gmail, use App Password)
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Email Addresses
EMAIL_SENDER=your-email@gmail.com
EMAIL_RECIPIENTS=recipient1@example.com,recipient2@example.com

# For Gmail:
# 1. Enable 2-Factor Authentication on your Google account
# 2. Generate an App Password: https://myaccount.google.com/apppasswords
# 3. Use the App Password as SMTP_PASSWORD

# For other SMTP providers, adjust SMTP_SERVER and SMTP_PORT accordingly:
# - Outlook/Office365: smtp.office365.com:587
# - Yahoo: smtp.mail.yahoo.com:587
# - Custom SMTP: your-smtp-server.com:port
